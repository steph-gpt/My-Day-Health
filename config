<script>
// ── DATA ──
const SCHEDULE = [
  {id:"s1",time:"8:00",label:"Morning buffer",type:"wellbeing",icon:"☀️",
   desc:"Slow start. Protect it. Your brain isn't online yet — this block works with that, not against it.",
   tasks:["Walk the dog","Read with coffee","Light stretch or movement","Quick kitchen tidy"]},
  {id:"s2",time:"10:00",label:"Become a person",type:"wellbeing",icon:"✨",
   desc:"Get dressed like you have somewhere to be — because you do. This signals to your brain the day is real.",
   tasks:["Skincare routine","Hair + get dressed (real outfit)"]},
  {id:"s3",time:"11:00",label:"Personal build",type:"build",icon:"🔨",
   desc:"Your voice, your future. Creative and generative — feeds you before the grind starts. Row whenever a thought needs chasing.",
   tasks:["LinkedIn / content creation","Website or consulting research","Podcast or idea development","General research / perspective building"],
   hasRowing:true},
  {id:"s4",time:"12:00",label:"Midday reset",type:"wellbeing",icon:"🥗",
   desc:"Two hours. Full dog walk, proper cooking, actual eating. Big nutritious lunch — dinner stays light. Do not rush this.",
   tasks:["Full dog walk","Cook a proper nutritious lunch","Eat properly — no desk, no phone"]},
  {id:"s5",time:"14:00",label:"Moxie Moments",type:"moxie",icon:"🎯",
   desc:"Peak window. Three hours of the work that changes your circumstances. Gamify it, build it — whatever gets you in.",
   tasks:["Follow up on existing applications","Tailor + submit new application (if applicable)","Interview prep or actual interview","Strategic conversations / new contacts","Update tracker (always)"]},
  {id:"s6",time:"17:00",label:"Movin the Booty",type:"wellbeing",icon:"🍑",
   desc:"45 minutes of movement then the dog gets her second walk. Gear shift. You earned this.",
   tasks:["Pilates video or light weights (45 min)","Afternoon dog walk"]},
  {id:"s7",time:"18:30",label:"Love Matters",type:"love",icon:"🤍",
   desc:"Light dinner, clean kitchen, check on your people. Close the day properly.",
   tasks:["Light dinner","Kitchen tidy"]},
];

const CAT = {
  moxie:    {color:"#E8A87C",bg:"rgba(232,168,124,0.12)",label:"Moxie"},
  wellbeing:{color:"#7CB9A8",bg:"rgba(124,185,168,0.12)",label:"Wellbeing"},
  build:    {color:"#A89FC9",bg:"rgba(168,159,201,0.12)",label:"Build"},
  love:     {color:"#C9909A",bg:"rgba(201,144,154,0.12)",label:"Love"},
};
const WEIGHTS = {moxie:0.45,wellbeing:0.25,build:0.20,love:0.10};

const KEYS = {
  state:"myday_state_v4", date:"myday_date_v4", rowing:"myday_rowing_v4",
  friends:"myday_friends_v2", token:"myday_gh_token", repo:"myday_gh_repo",
  history:"myday_history_v1", syncDate:"myday_sync_date"
};

function todayStr(){return new Date().toISOString().slice(0,10)}
function get(k){return localStorage.getItem(k)}
function set(k,v){localStorage.setItem(k,v)}

function loadState(){
  if(get(KEYS.date)!==todayStr()){
    localStorage.removeItem(KEYS.state);
    localStorage.removeItem(KEYS.rowing);
    set(KEYS.date,todayStr());
  }
  const r=get(KEYS.state);
  if(r)return JSON.parse(r);
  const s={};
  SCHEDULE.forEach(b=>b.tasks.forEach((_,i)=>{s[`${b.id}-${i}`]=false}));
  return s;
}

let state=loadState();
let rowingCount=parseInt(get(KEYS.rowing)||"0");
let friends=JSON.parse(get(KEYS.friends)||"[]");
let history=JSON.parse(get(KEYS.history)||"{}");
let expandedBlock=null,expandedFriend=null,editingFriendId=null;

// ── SETUP ──
function checkSetup(){
  if(!get(KEYS.token)||!get(KEYS.repo)){
    document.getElementById("setupScreen").classList.add("show");
    return false;
  }
  return true;
}

async function completeSetup(){
  const token=document.getElementById("setupToken").value.trim();
  const repo=document.getElementById("setupRepo").value.trim();
  if(!token||!repo){return}
  const err=document.getElementById("setupError");
  err.style.display="none";
  try{
    const r=await fetch(`https://api.github.com/repos/${repo}`,{
      headers:{"Authorization":`token ${token}`,"Accept":"application/vnd.github.v3+json"}
    });
    if(!r.ok)throw new Error("Bad token or repo");
    set(KEYS.token,token);
    set(KEYS.repo,repo);
    document.getElementById("setupScreen").classList.remove("show");
    init();
  }catch(e){err.style.display="block"}
}

// ── TABS ──
function switchTab(tab){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById(`page-${tab}`).classList.add('active');
  document.getElementById(`tab-${tab}`).classList.add('active');
  if(tab==='friends')renderFriends();
  if(tab==='history')renderHistory();
  if(tab==='settings')loadSettings();
}

// ── SCORE ──
function calcScore(){
  const counts={moxie:[0,0],wellbeing:[0,0],build:[0,0],love:[0,0]};
  SCHEDULE.forEach(b=>b.tasks.forEach((_,i)=>{
    counts[b.type][1]++;
    if(state[`${b.id}-${i}`])counts[b.type][0]++;
  }));
  let score=0;
  Object.entries(WEIGHTS).forEach(([cat,w])=>{
    const[d,t]=counts[cat];
    score+=(t>0?d/t:0)*w*100;
  });
  return{score:Math.round(score),counts};
}

function updateScore(){
  const{score,counts}=calcScore();
  const circ=2*Math.PI*40,dash=(score/100)*circ;
  const arc=document.getElementById("scoreArc");
  arc.setAttribute("stroke-dasharray",`${dash} ${circ}`);
  const col=score>=80?"#7CB9A8":score>=55?"#E8A87C":"#D07070";
  arc.setAttribute("stroke",col);
  const num=document.getElementById("scoreNum");
  num.textContent=score;num.style.color=col;
  const total=Object.keys(state).length,done=Object.values(state).filter(Boolean).length;
  document.getElementById("scoreTasks").textContent=`${done} of ${total} tasks · weighted`;
  const setBar=(id,cnt,bar)=>{const[d,t]=cnt;document.getElementById(id).textContent=`${d}/${t}`;document.getElementById(bar).style.width=t>0?`${Math.round(d/t*100)}%`:"0%"};
  setBar("jsCount",counts.moxie,"jsBar");
  setBar("wbCount",counts.wellbeing,"wbBar");
  setBar("bdCount",counts.build,"bdBar");
  setBar("lvCount",counts.love,"lvBar");
  document.getElementById("rowingTotal").textContent=rowingCount;
  document.getElementById("completeBanner").classList.toggle("show",done===total&&total>0);
  // save today's score to local history
  if(score>0){
    history[todayStr()]={score,counts:Object.fromEntries(Object.entries(counts).map(([k,[d,t]])=>[k,t>0?Math.round(d/t*100):0])),rowing:rowingCount};
    set(KEYS.history,JSON.stringify(history));
  }
}

// ── GITHUB SYNC ──
async function syncToGitHub(){
  const token=get(KEYS.token),repo=get(KEYS.repo);
  if(!token||!repo)return;
  setSyncStatus("syncing","Syncing...");
  try{
    const path="data/scores.json";
    const url=`https://api.github.com/repos/${repo}/contents/${path}`;
    const headers={"Authorization":`token ${token}`,"Accept":"application/vnd.github.v3+json","Content-Type":"application/json"};
    // get existing file
    let sha=null,existing={};
    try{
      const r=await fetch(url,{headers});
      if(r.ok){const d=await r.json();sha=d.sha;existing=JSON.parse(atob(d.content.replace(/\n/g,"")));}
    }catch(e){}
    const merged={...existing,...history};
    const content=btoa(unescape(encodeURIComponent(JSON.stringify(merged,null,2))));
    const body={message:`Day score ${todayStr()}`,content};
    if(sha)body.sha=sha;
    const r2=await fetch(url,{method:"PUT",headers,body:JSON.stringify(body)});
    if(!r2.ok)throw new Error("Sync failed");
    set(KEYS.syncDate,todayStr());
    setSyncStatus("synced",`Synced ${new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}`);
  }catch(e){setSyncStatus("error","Sync failed — check settings")}
}

function setSyncStatus(state,text){
  const dot=document.getElementById("syncDot"),txt=document.getElementById("syncText");
  dot.className="sync-dot "+state;txt.textContent=text;
}

function checkSyncStatus(){
  const sd=get(KEYS.syncDate);
  if(sd===todayStr())setSyncStatus("synced","Synced today");
  else setSyncStatus("","Not synced yet today");
}

// ── BLOCKS ──
function getCurrentBlockId(){
  const now=new Date(),mins=now.getHours()*60+now.getMinutes();
  let cur=null;
  SCHEDULE.forEach((b,i)=>{
    const[h,m]=b.time.split(":").map(Number),start=h*60+m;
    const next=SCHEDULE[i+1];
    const end=next?(()=>{const[nh,nm]=next.time.split(":").map(Number);return nh*60+nm})():start+120;
    if(mins>=start&&mins<end)cur=b.id;
  });
  return cur;
}

function renderBlocks(){
  const curId=getCurrentBlockId(),list=document.getElementById("blocksList");
  list.innerHTML="";
  SCHEDULE.forEach(block=>{
    const cat=CAT[block.type],isCurrent=block.id===curId;
    const done=block.tasks.filter((_,i)=>state[`${block.id}-${i}`]).length;
    const pct=Math.round(done/block.tasks.length*100),isOpen=expandedBlock===block.id;
    const div=document.createElement("div");
    div.className="block"+(isCurrent?" current":"");
    if(isCurrent){div.style.setProperty("--c",cat.color);div.style.setProperty("--cbg",cat.bg)}
    const taskHTML=block.tasks.map((task,i)=>{
      const checked=state[`${block.id}-${i}`];
      return`<div class="task-item" onclick="toggleTask('${block.id}',${i})">
        <div class="task-box${checked?" done":""}" style="${checked?`background:${cat.color};border-color:${cat.color}`:""}"></div>
        <div class="task-label${checked?" done":""}">${task}</div></div>`;
    }).join("");
    const rowHTML=block.hasRowing?`<div class="rowing-block"><div class="rowing-counter-row">
      <div style="font-size:13px">🚣 5-min row sessions</div>
      <div class="rowing-counter-right"><div class="row-count-display" id="rowDisplay">${rowingCount}</div>
      <button class="row-plus-btn" onclick="addRow(event)">+</button></div></div></div>`:"";
    div.innerHTML=`<div class="block-header" onclick="toggleBlock('${block.id}')">
      <div class="block-icon">${block.icon}</div>
      <div class="block-meta">
        <div class="block-tags"><span class="block-time">${block.time}</span>
        ${isCurrent?`<span class="now-badge" style="background:${cat.color}">Now</span>`:""}
        <span class="block-badge" style="background:${cat.bg};color:${cat.color}">${cat.label}</span></div>
        <div class="block-name">${block.label}</div>
      </div>
      <div class="block-right">
        <div><div class="block-frac" style="color:${pct===100?cat.color:"var(--muted)"}">${done}/${block.tasks.length}</div>
        <div class="block-mini-bar"><div class="block-mini-fill" style="background:${cat.color};width:${pct}%"></div></div></div>
        <div class="block-chevron${isOpen?" open":""}" id="chev-${block.id}">▼</div>
      </div></div>
      <div class="block-body${isOpen?" open":""}" id="body-${block.id}">
        <div class="block-desc">${block.desc}</div>${rowHTML}${taskHTML}</div>`;
    list.appendChild(div);
  });
}

function toggleBlock(id){expandedBlock=expandedBlock===id?null:id;renderBlocks()}
function toggleTask(blockId,idx){
  state[`${blockId}-${idx}`]=!state[`${blockId}-${idx}`];
  set(KEYS.state,JSON.stringify(state));
  renderBlocks();updateScore();
}
function addRow(e){
  e.stopPropagation();rowingCount++;
  set(KEYS.rowing,String(rowingCount));
  const d=document.getElementById("rowDisplay");if(d)d.textContent=rowingCount;
  updateScore();
}
function confirmReset(){
  if(confirm("Reset all tasks for today?")){
    Object.keys(state).forEach(k=>state[k]=false);
    rowingCount=0;
    set(KEYS.state,JSON.stringify(state));
    set(KEYS.rowing,"0");
    renderBlocks();updateScore();
  }
}
function toggleWhy(w){
  const body=document.getElementById(`${w}Why`),arrow=document.getElementById(`${w}Arrow`);
  const open=body.classList.contains("open");
  body.classList.toggle("open",!open);arrow.classList.toggle("open",!open);
}

// ── HISTORY ──
function renderHistory(){
  const content=document.getElementById("historyContent");
  const entries=Object.entries(history).sort((a,b)=>a[0]<b[0]?-1:1);
  const subtitle=document.getElementById("historySubtitle");

  if(entries.length===0){
    subtitle.textContent="No data yet — complete your first day to start tracking";
    content.innerHTML=`<div class="no-data">Your progress graph will appear here after your first full day.<br><br>Complete tasks, sync to GitHub, and come back tomorrow.</div>`;
    return;
  }

  subtitle.textContent=`${entries.length} day${entries.length===1?"":"s"} tracked`;
  const scores=entries.map(([,v])=>v.score);
  const avg=Math.round(scores.reduce((a,b)=>a+b,0)/scores.length);
  const best=Math.max(...scores);

  // streaks
  let streak=0,maxStreak=0,tempStreak=0;
  const today=todayStr();
  const sortedDates=entries.map(([d])=>d).sort();
  for(let i=sortedDates.length-1;i>=0;i--){
    const d=new Date(sortedDates[i]);
    const expected=new Date(today);expected.setDate(expected.getDate()-(sortedDates.length-1-i));
    if(d.toISOString().slice(0,10)===expected.toISOString().slice(0,10)&&history[sortedDates[i]].score>=50){streak++;}
    else break;
  }
  for(let i=0;i<sortedDates.length;i++){
    if(history[sortedDates[i]].score>=50){tempStreak++;maxStreak=Math.max(maxStreak,tempStreak);}
    else tempStreak=0;
  }

  // category averages
  const catAvgs={moxie:0,wellbeing:0,build:0,love:0};
  const catKeys=Object.keys(catAvgs);
  entries.forEach(([,v])=>catKeys.forEach(k=>{catAvgs[k]+=(v.counts?.[k]||0)}));
  catKeys.forEach(k=>catAvgs[k]=Math.round(catAvgs[k]/entries.length));

  // last 30 days for chart
  const last30=entries.slice(-30);
  const chartDates=last30.map(([d])=>d.slice(5));
  const chartScores=last30.map(([,v])=>v.score);

  content.innerHTML=`
    <div class="stat-cards">
      <div class="stat-card"><div class="stat-card-val" style="color:var(--orange)">${avg}</div><div class="stat-card-label">Average</div><div class="stat-card-sub">across all days</div></div>
      <div class="stat-card"><div class="stat-card-val" style="color:var(--teal)">${best}</div><div class="stat-card-label">Best Day</div><div class="stat-card-sub">your personal peak</div></div>
      <div class="stat-card"><div class="stat-card-val" style="color:var(--purple)">${streak}</div><div class="stat-card-label">Streak</div><div class="stat-card-sub">days ≥50 in a row</div></div>
      <div class="stat-card"><div class="stat-card-val" style="color:var(--rose)">${maxStreak}</div><div class="stat-card-label">Best Streak</div><div class="stat-card-sub">all time</div></div>
    </div>
    <div class="chart-card">
      <div class="chart-title">Last ${last30.length} Days — Day Score</div>
      <div class="chart-wrap"><canvas id="historyChart"></canvas></div>
      <div class="chart-legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--orange)"></div>Score</div>
        <div class="legend-item"><div class="legend-dot" style="background:rgba(124,185,168,0.5)"></div>50+ threshold</div>
      </div>
    </div>
    <div class="cat-breakdown">
      <div class="breakdown-title">Category Averages</div>
      <div class="breakdown-row"><div class="breakdown-label" style="color:var(--orange)">Moxie</div><div class="breakdown-bar-wrap"><div class="breakdown-bar" style="background:var(--orange);width:${catAvgs.moxie}%"></div></div><div class="breakdown-val">${catAvgs.moxie}%</div></div>
      <div class="breakdown-row"><div class="breakdown-label" style="color:var(--teal)">Wellbeing</div><div class="breakdown-bar-wrap"><div class="breakdown-bar" style="background:var(--teal);width:${catAvgs.wellbeing}%"></div></div><div class="breakdown-val">${catAvgs.wellbeing}%</div></div>
      <div class="breakdown-row"><div class="breakdown-label" style="color:var(--purple)">Build</div><div class="breakdown-bar-wrap"><div class="breakdown-bar" style="background:var(--purple);width:${catAvgs.build}%"></div></div><div class="breakdown-val">${catAvgs.build}%</div></div>
      <div class="breakdown-row"><div class="breakdown-label" style="color:var(--rose)">Love</div><div class="breakdown-bar-wrap"><div class="breakdown-bar" style="background:var(--rose);width:${catAvgs.love}%"></div></div><div class="breakdown-val">${catAvgs.love}%</div></div>
    </div>
    <div class="streak-card" style="margin:12px 14px 0;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:18px">
      <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px">Last 14 Days</div>
      <div class="streak-row">${last30.slice(-14).map(([d,v])=>{
        const score=v.score;
        const col=score>=80?"#7CB9A8":score>=50?"#E8A87C":"rgba(245,240,232,0.1)";
        const day=new Date(d+'T12:00:00').toLocaleDateString('en',{weekday:'narrow'});
        return`<div class="streak-day" style="background:${col}20;border:1px solid ${col}40">
          <span style="font-size:11px;font-family:'Playfair Display',serif;color:${score>0?col:"var(--dim)"}">${score>0?score:'-'}</span>
          <span class="streak-day-label">${day}</span></div>`;
      }).join("")}</div>
    </div>`;

  // draw chart
  setTimeout(()=>{
    const canvas=document.getElementById("historyChart");
    if(!canvas)return;
    const ctx=canvas.getContext("2d");
    const W=canvas.offsetWidth,H=160;
    canvas.width=W*window.devicePixelRatio;canvas.height=H*window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio,window.devicePixelRatio);
    const pad={t:10,r:10,b:24,l:28};
    const cW=W-pad.l-pad.r,cH=H-pad.t-pad.b;
    const n=chartScores.length;
    if(n<1)return;
    const xStep=cW/(Math.max(n-1,1));
    const yScale=v=>pad.t+cH-(v/100)*cH;
    // grid
    ctx.strokeStyle="rgba(245,240,232,0.06)";ctx.lineWidth=1;
    [0,25,50,75,100].forEach(y=>{
      const yy=yScale(y);
      ctx.beginPath();ctx.moveTo(pad.l,yy);ctx.lineTo(pad.l+cW,yy);ctx.stroke();
      ctx.fillStyle="rgba(245,240,232,0.25)";ctx.font="9px monospace";ctx.textAlign="right";
      ctx.fillText(y,pad.l-4,yy+3);
    });
    // threshold line
    ctx.strokeStyle="rgba(124,185,168,0.3)";ctx.setLineDash([4,4]);ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(pad.l,yScale(50));ctx.lineTo(pad.l+cW,yScale(50));ctx.stroke();
    ctx.setLineDash([]);
    // fill
    const grad=ctx.createLinearGradient(0,pad.t,0,pad.t+cH);
    grad.addColorStop(0,"rgba(232,168,124,0.3)");grad.addColorStop(1,"rgba(232,168,124,0)");
    ctx.fillStyle=grad;
    ctx.beginPath();
    chartScores.forEach((s,i)=>{const x=pad.l+i*xStep,y=yScale(s);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});
    ctx.lineTo(pad.l+(n-1)*xStep,yScale(0));ctx.lineTo(pad.l,yScale(0));ctx.closePath();ctx.fill();
    // line
    ctx.strokeStyle="#E8A87C";ctx.lineWidth=2;ctx.lineJoin="round";ctx.lineCap="round";
    ctx.beginPath();
    chartScores.forEach((s,i)=>{const x=pad.l+i*xStep,y=yScale(s);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y)});
    ctx.stroke();
    // dots
    chartScores.forEach((s,i)=>{
      const x=pad.l+i*xStep,y=yScale(s);
      ctx.fillStyle=s>=80?"#7CB9A8":s>=50?"#E8A87C":"#D07070";
      ctx.beginPath();ctx.arc(x,y,3,0,Math.PI*2);ctx.fill();
    });
    // x labels — show every ~5
    ctx.fillStyle="rgba(245,240,232,0.3)";ctx.font="8px monospace";ctx.textAlign="center";
    chartDates.forEach((d,i)=>{if(i%5===0||i===n-1)ctx.fillText(d,pad.l+i*xStep,H-6)});
  },50);
}

// ── FRIENDS ──
function daysSince(d){if(!d)return 999;return Math.floor((Date.now()-new Date(d).getTime())/86400000)}
function isOverdue(f){return daysSince(f.lastContact)>=(f.tier==="close"?3:14)}
const ACOLORS=["#E8A87C","#7CB9A8","#A89FC9","#C9909A","#8BA8C9","#C9C490"];

function renderFriends(){
  const list=document.getElementById("friendsList");list.innerHTML="";
  const over=friends.filter(isOverdue);
  document.getElementById("overdueCount").textContent=over.length;
  document.getElementById("overdueBanner").classList.toggle("show",over.length>0);
  const sorted=[...friends].sort((a,b)=>{
    const ao=isOverdue(a)?-1:0,bo=isOverdue(b)?-1:0;
    if(ao!==bo)return ao-bo;
    return daysSince(a.lastContact)-daysSince(b.lastContact);
  });
  sorted.forEach(f=>{
    const days=daysSince(f.lastContact),thr=f.tier==="close"?3:14,over=days>=thr;
    const ci=Math.abs(f.name.charCodeAt(0))%ACOLORS.length,ac=ACOLORS[ci];
    const isOpen=expandedFriend===f.id;
    const dc=over?(days>=thr*2?"#C9909A":"#E8A87C"):"#7CB9A8";
    const initials=f.name.split(" ").map(w=>w[0]).join("").slice(0,2).toUpperCase();
    const card=document.createElement("div");
    card.className="friend-card"+(over&&days>=thr*2?" overdue-high":over?" overdue-low":"");
    card.innerHTML=`<div class="friend-header" onclick="toggleFriend('${f.id}')">
      <div class="friend-avatar" style="background:${ac}20;color:${ac};border:1.5px solid ${ac}40">${initials}</div>
      <div class="friend-info"><div class="friend-name">${f.name}</div>
      <div class="friend-meta">${f.tier==="close"?"Close · 3-day nudge":"Wider · 14-day nudge"}</div></div>
      <div class="friend-status"><div class="friend-days" style="color:${dc}">${f.lastContact?days+"d ago":"Never"}</div>
      <div class="friend-days-label">last contact</div></div></div>
      <div class="friend-body${isOpen?" open":""}" id="fb-${f.id}">
        <div class="friend-notes">${f.notes||"<em>No notes yet.</em>"}</div>
        <div class="friend-actions">
          <button class="friend-btn primary" onclick="logContact('${f.id}')">✓ Reached out</button>
          <button class="friend-btn" onclick="editFriend('${f.id}')">Edit</button>
          <button class="friend-btn danger" onclick="deleteFriend('${f.id}')">Remove</button>
        </div></div>`;
    list.appendChild(card);
  });
  if(!friends.length)list.innerHTML=`<div class="no-data">No one added yet.<br>Start with the people who matter most.</div>`;
}

function toggleFriend(id){expandedFriend=expandedFriend===id?null:id;renderFriends()}
function logContact(id){const f=friends.find(f=>f.id===id);if(f){f.lastContact=new Date().toISOString();set(KEYS.friends,JSON.stringify(friends));renderFriends()}}
function deleteFriend(id){if(confirm("Remove?")){ friends=friends.filter(f=>f.id!==id);set(KEYS.friends,JSON.stringify(friends));renderFriends()}}
function editFriend(id){
  const f=friends.find(f=>f.id===id);if(!f)return;
  editingFriendId=id;
  document.getElementById("modalTitle").textContent="Edit";
  document.getElementById("fName").value=f.name;
  document.getElementById("fTier").value=f.tier;
  document.getElementById("fNotes").value=f.notes||"";
  document.getElementById("friendModal").classList.add("show");
}
function openAddFriend(){
  editingFriendId=null;
  document.getElementById("modalTitle").textContent="Add someone";
  document.getElementById("fName").value="";
  document.getElementById("fTier").value="close";
  document.getElementById("fNotes").value="";
  document.getElementById("friendModal").classList.add("show");
}
function closeModal(){document.getElementById("friendModal").classList.remove("show")}
function saveFriend(){
  const name=document.getElementById("fName").value.trim();if(!name)return;
  const tier=document.getElementById("fTier").value,notes=document.getElementById("fNotes").value.trim();
  if(editingFriendId){const f=friends.find(f=>f.id===editingFriendId);if(f){f.name=name;f.tier=tier;f.notes=notes}}
  else friends.push({id:Date.now().toString(),name,tier,notes,lastContact:null});
  set(KEYS.friends,JSON.stringify(friends));closeModal();renderFriends();
}

// ── SETTINGS ──
function loadSettings(){
  document.getElementById("settingsRepo").value=get(KEYS.repo)||"steph-gpt/My-day-health";
  document.getElementById("settingsToken").value=get(KEYS.token)||"";
}
async function saveSettings(){
  const token=document.getElementById("settingsToken").value.trim();
  const repo=document.getElementById("settingsRepo").value.trim();
  const msg=document.getElementById("settingsMsg");
  msg.style.color="var(--muted)";msg.textContent="Testing...";
  try{
    const r=await fetch(`https://api.github.com/repos/${repo}`,{
      headers:{"Authorization":`token ${token}`,"Accept":"application/vnd.github.v3+json"}
    });
    if(!r.ok)throw new Error();
    set(KEYS.token,token);set(KEYS.repo,repo);
    msg.style.color="var(--teal)";msg.textContent="✓ Connected successfully";
  }catch(e){msg.style.color="var(--rose)";msg.textContent="✗ Could not connect — check token & repo"}
}
function clearAllData(){
  if(confirm("Clear all local data? This cannot be undone.")){
    Object.values(KEYS).forEach(k=>localStorage.removeItem(k));
    location.reload();
  }
}

// ── INIT ──
function setDate(){
  document.getElementById("headerDate").textContent=new Date().toLocaleDateString("en-CA",{weekday:"long",month:"long",day:"numeric"});
}

function init(){
  setDate();renderBlocks();updateScore();checkSyncStatus();
  setInterval(()=>{renderBlocks();updateScore()},60000);
  // auto-sync at end of day (17:30+)
  const h=new Date().getHours();
  if(h>=17&&get(KEYS.syncDate)!==todayStr())syncToGitHub();
}

if(checkSetup())init();
</script>
