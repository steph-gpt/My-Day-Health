<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="My Day">
<title>My Day</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #1A1612; --surface: rgba(245,240,232,0.04); --border: rgba(245,240,232,0.08);
  --text: #F5F0E8; --muted: rgba(245,240,232,0.45); --dim: rgba(245,240,232,0.18);
  --orange: #E8A87C; --teal: #7CB9A8; --purple: #A89FC9; --rose: #C9909A;
  --orange-bg: rgba(232,168,124,0.12); --teal-bg: rgba(124,185,168,0.12);
  --purple-bg: rgba(168,159,201,0.12); --rose-bg: rgba(201,144,154,0.12);
  --safe-top: env(safe-area-inset-top,0px); --safe-bottom: env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow-x:hidden;background:var(--bg);color:var(--text);font-family:'Lora',serif}
body{padding-top:var(--safe-top);padding-bottom:calc(var(--safe-bottom)+70px);
  background-image:radial-gradient(ellipse at 15% 0%,rgba(232,168,124,0.07) 0%,transparent 55%),
  radial-gradient(ellipse at 85% 100%,rgba(124,185,168,0.05) 0%,transparent 55%)}
::-webkit-scrollbar{display:none}

/* SETUP SCREEN */
#setupScreen{position:fixed;inset:0;background:var(--bg);z-index:1000;overflow-y:auto;
  padding:calc(var(--safe-top)+32px) 24px calc(var(--safe-bottom)+40px);display:none}
#setupScreen.show{display:block}
.setup-emoji{font-size:52px;text-align:center;margin-bottom:16px}
.setup-title{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;text-align:center;margin-bottom:8px}
.setup-sub{font-size:14px;color:var(--muted);text-align:center;line-height:1.7;font-style:italic;margin-bottom:32px}
.setup-step{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:18px;margin-bottom:12px}
.setup-step h4{font-family:'Playfair Display',serif;font-size:16px;margin-bottom:6px;color:var(--orange)}
.setup-step p{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:10px}
.setup-step code{background:rgba(232,168,124,0.15);padding:2px 6px;border-radius:4px;font-family:monospace;font-size:12px;color:var(--orange)}
.setup-input{width:100%;background:rgba(245,240,232,0.07);border:1px solid var(--border);border-radius:10px;
  padding:13px 16px;color:var(--text);font-family:'Lora',serif;font-size:14px;outline:none;margin-top:4px}
.setup-input:focus{border-color:rgba(232,168,124,0.5)}
.setup-btn{width:100%;background:var(--orange);color:#1A1612;border:none;border-radius:14px;
  padding:16px;font-family:'Lora',serif;font-size:14px;font-weight:700;letter-spacing:1px;
  text-transform:uppercase;cursor:pointer;margin-top:20px}
.setup-note{font-size:12px;color:var(--dim);text-align:center;line-height:1.6;margin-top:16px;font-style:italic}
.setup-error{color:var(--rose);font-size:13px;text-align:center;margin-top:10px;display:none}

/* TAB BAR */
.tab-bar{position:fixed;bottom:0;left:0;right:0;background:rgba(26,22,18,0.95);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(--border);
  display:flex;z-index:200;padding-bottom:var(--safe-bottom)}
.tab-btn{flex:1;background:none;border:none;color:var(--muted);font-family:'Lora',serif;
  font-size:10px;letter-spacing:1px;text-transform:uppercase;padding:12px 4px 10px;
  display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;transition:color 0.2s}
.tab-btn.active{color:var(--orange)}
.tab-btn svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}

.page{display:none;padding-bottom:90px}
.page.active{display:block}

/* HEADER */
.header{padding:24px 20px 18px;border-bottom:1px solid var(--border);position:sticky;top:0;
  background:rgba(26,22,18,0.93);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);z-index:100}
.header-date{font-size:10px;letter-spacing:3px;color:var(--orange);text-transform:uppercase;margin-bottom:3px}
.header-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;letter-spacing:-0.3px}
.header-sub{font-size:12px;color:var(--muted);font-style:italic;margin-top:2px}

/* SCORE CARD */
.score-card{margin:16px 14px 0;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:18px}
.score-row{display:flex;align-items:center;gap:16px;margin-bottom:16px}
.score-ring-wrap{position:relative;flex-shrink:0}
.score-ring-wrap svg{display:block}
.score-text-wrap{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.score-num{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;line-height:1}
.score-info{flex:1}
.score-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:2px}
.score-tasks{font-size:11px;color:var(--muted);line-height:1.5;margin-bottom:12px}
.cat-row{margin-bottom:8px}
.cat-row-top{display:flex;justify-content:space-between;margin-bottom:3px}
.cat-name{font-size:10px;letter-spacing:1px;text-transform:uppercase}
.cat-count{font-size:10px;color:var(--muted)}
.progress-track{height:4px;background:rgba(245,240,232,0.08);border-radius:2px}
.progress-fill{height:100%;border-radius:2px;transition:width 0.5s cubic-bezier(0.34,1.56,0.64,1)}
.rowing-stat{display:flex;align-items:center;justify-content:space-between;margin-top:14px;
  padding-top:14px;border-top:1px solid var(--border)}
.rowing-count{font-family:'Playfair Display',serif;font-size:20px;color:var(--teal)}

/* SYNC STATUS */
.sync-row{display:flex;align-items:center;justify-content:space-between;margin-top:14px;
  padding-top:14px;border-top:1px solid var(--border)}
.sync-status{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:6px}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--dim);flex-shrink:0}
.sync-dot.synced{background:var(--teal)}
.sync-dot.error{background:var(--rose)}
.sync-dot.syncing{background:var(--orange);animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
.sync-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:'Lora',serif;
  font-size:10px;letter-spacing:1px;text-transform:uppercase;padding:6px 12px;border-radius:16px;cursor:pointer}

/* WHY */
.why-section{margin-top:14px;border-top:1px solid var(--border);padding-top:12px}
.why-btn{display:flex;align-items:center;gap:8px;background:none;border:none;color:inherit;
  font-family:'Lora',serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;
  padding:5px 0;cursor:pointer;width:100%}
.why-arrow{font-size:9px;transition:transform 0.2s ease;display:inline-block}
.why-arrow.open{transform:rotate(90deg)}
.why-body{font-size:13px;line-height:1.7;font-style:italic;color:rgba(245,240,232,0.75);
  padding:10px 12px;border-radius:10px;margin:4px 0 8px;display:none}
.why-body.open{display:block}

.section-label{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--dim);padding:20px 18px 10px}
.blocks-list{padding:0 14px;display:flex;flex-direction:column;gap:6px}
.block{border:1px solid var(--border);border-radius:14px;overflow:hidden;background:rgba(245,240,232,0.02)}
.block.current{border-color:var(--c,var(--orange));background:var(--cbg,var(--orange-bg))}
.block-header{padding:13px 14px;display:flex;align-items:center;gap:11px;cursor:pointer;
  min-height:58px;-webkit-user-select:none;user-select:none}
.block-icon{font-size:19px;min-width:24px;text-align:center}
.block-meta{flex:1;min-width:0}
.block-tags{display:flex;align-items:center;gap:5px;margin-bottom:3px;flex-wrap:wrap}
.block-time{font-size:10px;color:var(--muted);font-family:monospace}
.block-badge{font-size:8px;padding:2px 5px;border-radius:4px;letter-spacing:1px;text-transform:uppercase;font-weight:700;font-family:'Lora',serif}
.now-badge{font-size:8px;padding:2px 5px;border-radius:4px;letter-spacing:1px;text-transform:uppercase;font-weight:700;font-family:'Lora',serif;color:#1A1612}
.block-name{font-family:'Playfair Display',serif;font-size:14px;color:var(--text);line-height:1.2}
.block-right{display:flex;align-items:center;gap:8px;flex-shrink:0}
.block-frac{font-size:11px;color:var(--muted);text-align:right}
.block-mini-bar{width:32px;height:3px;background:rgba(245,240,232,0.1);border-radius:2px;margin-top:3px}
.block-mini-fill{height:100%;border-radius:2px;transition:width 0.3s}
.block-chevron{font-size:10px;color:var(--dim);transition:transform 0.25s ease}
.block-chevron.open{transform:rotate(180deg)}
.block-body{border-top:1px solid var(--border);padding:12px 14px 14px;display:none}
.block-body.open{display:block}
.block-desc{font-size:12px;color:var(--muted);line-height:1.65;font-style:italic;margin-bottom:12px}
.task-item{display:flex;align-items:center;gap:11px;padding:8px 0;cursor:pointer;
  border-bottom:1px solid rgba(245,240,232,0.05);-webkit-user-select:none;user-select:none}
.task-item:last-child{border-bottom:none}
.task-box{width:22px;height:22px;border-radius:6px;border:2px solid var(--dim);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;transition:all 0.15s}
.task-box.done::after{content:'✓';font-size:12px;font-weight:700;color:#1A1612}
.task-label{font-size:13px;line-height:1.4;flex:1;transition:all 0.15s}
.task-label.done{color:var(--dim);text-decoration:line-through}
.rowing-block{margin:12px 0 4px}
.rowing-counter-row{display:flex;align-items:center;justify-content:space-between;
  padding:10px 0;border-bottom:1px solid rgba(245,240,232,0.05)}
.rowing-counter-right{display:flex;align-items:center;gap:12px}
.row-count-display{font-family:'Playfair Display',serif;font-size:18px;color:var(--teal);min-width:24px;text-align:center}
.row-plus-btn{background:var(--teal-bg);border:1px solid rgba(124,185,168,0.3);color:var(--teal);
  border-radius:8px;padding:6px 14px;font-size:18px;cursor:pointer}
.reset-wrap{text-align:center;padding:24px 0 8px}
.reset-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:'Lora',serif;
  font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:10px 20px;border-radius:20px;cursor:pointer}
.complete-banner{margin:16px 14px 0;background:var(--teal-bg);border:1px solid rgba(124,185,168,0.3);
  border-radius:14px;padding:16px 18px;text-align:center;display:none}
.complete-banner.show{display:block}
.complete-banner h3{font-family:'Playfair Display',serif;font-size:17px;font-style:italic;color:var(--teal);margin-bottom:4px}
.complete-banner p{font-size:12px;color:var(--muted)}

/* HISTORY PAGE */
.history-header{padding:24px 18px 16px;border-bottom:1px solid var(--border);position:sticky;top:0;
  background:rgba(26,22,18,0.93);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);z-index:100}
.history-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;margin-bottom:3px}
.history-sub{font-size:12px;color:var(--muted);font-style:italic}
.stat-cards{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:16px 14px 0}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px}
.stat-card-val{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;line-height:1;margin-bottom:4px}
.stat-card-label{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--muted)}
.stat-card-sub{font-size:11px;color:var(--dim);margin-top:3px}
.chart-card{margin:12px 14px 0;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:18px}
.chart-title{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
.chart-wrap{position:relative;height:160px;margin-bottom:8px}
canvas#historyChart{width:100%!important;height:160px!important}
.chart-legend{display:flex;gap:14px;flex-wrap:wrap;margin-top:10px}
.legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted)}
.legend-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.cat-breakdown{margin:12px 14px 0;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:18px}
.breakdown-title{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.breakdown-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.breakdown-label{font-size:12px;color:var(--muted);width:70px;flex-shrink:0}
.breakdown-bar-wrap{flex:1;height:8px;background:rgba(245,240,232,0.08);border-radius:4px;overflow:hidden}
.breakdown-bar{height:100%;border-radius:4px;transition:width 0.6s cubic-bezier(0.34,1.56,0.64,1)}
.breakdown-val{font-size:12px;color:var(--muted);width:30px;text-align:right;flex-shrink:0}
.streak-card{margin:12px 14px 0;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:18px}
.streak-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.streak-day{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;
  font-size:10px;font-family:'Lora',serif;flex-direction:column;gap:1px}
.streak-day-label{font-size:8px;color:var(--dim)}
.no-data{text-align:center;padding:40px 20px;color:var(--muted);font-style:italic;font-size:14px;line-height:1.7}

/* FRIENDS PAGE */
.friends-header{padding:24px 18px 16px;border-bottom:1px solid var(--border);position:sticky;top:0;
  background:rgba(26,22,18,0.93);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);z-index:100}
.friends-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;margin-bottom:3px}
.friends-sub{font-size:12px;color:var(--muted);font-style:italic}
.add-friend-btn{display:flex;align-items:center;gap:8px;margin:14px 14px 0;background:var(--orange-bg);
  border:1px solid rgba(232,168,124,0.25);border-radius:12px;padding:12px 16px;cursor:pointer;
  color:var(--orange);font-family:'Lora',serif;font-size:13px;width:calc(100% - 28px)}
.friends-list{padding:12px 14px;display:flex;flex-direction:column;gap:8px}
.friend-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.friend-card.overdue-high{border-color:rgba(201,144,154,0.4)}
.friend-card.overdue-low{border-color:rgba(232,168,124,0.3)}
.friend-header{padding:13px 14px;display:flex;align-items:center;gap:11px;cursor:pointer}
.friend-avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-family:'Playfair Display',serif;font-size:14px;font-weight:700;flex-shrink:0}
.friend-info{flex:1;min-width:0}
.friend-name{font-family:'Playfair Display',serif;font-size:15px;margin-bottom:2px}
.friend-meta{font-size:11px;color:var(--muted)}
.friend-status{flex-shrink:0;text-align:right}
.friend-days{font-family:'Playfair Display',serif;font-size:16px}
.friend-days-label{font-size:9px;color:var(--muted);letter-spacing:1px;text-transform:uppercase}
.friend-body{border-top:1px solid var(--border);padding:12px 14px 14px;display:none}
.friend-body.open{display:block}
.friend-notes{font-size:13px;color:var(--muted);line-height:1.6;font-style:italic;margin-bottom:12px}
.friend-actions{display:flex;gap:8px;flex-wrap:wrap}
.friend-btn{background:none;border:1px solid var(--border);color:var(--muted);font-family:'Lora',serif;
  font-size:11px;letter-spacing:1px;text-transform:uppercase;padding:8px 14px;border-radius:20px;cursor:pointer}
.friend-btn.primary{background:var(--teal-bg);border-color:rgba(124,185,168,0.3);color:var(--teal)}
.friend-btn.danger{border-color:rgba(201,144,154,0.3);color:var(--rose)}
.overdue-banner{margin:14px 14px 0;background:var(--rose-bg);border:1px solid rgba(201,144,154,0.25);
  border-radius:12px;padding:12px 16px;display:none}
.overdue-banner.show{display:flex;align-items:center;gap:10px}
.overdue-banner-text{font-size:13px;color:var(--rose)}
.overdue-banner-count{font-family:'Playfair Display',serif;font-size:22px;color:var(--rose);flex-shrink:0}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(10,8,6,0.85);z-index:500;display:none;align-items:flex-end}
.modal-overlay.show{display:flex}
.modal{background:#221E1A;border-radius:20px 20px 0 0;padding:24px 20px;width:100%;
  padding-bottom:calc(20px + var(--safe-bottom))}
.modal-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;margin-bottom:18px}
.modal-field{margin-bottom:14px}
.modal-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;display:block}
.modal-input{width:100%;background:rgba(245,240,232,0.06);border:1px solid var(--border);border-radius:10px;
  padding:11px 14px;color:var(--text);font-family:'Lora',serif;font-size:14px;outline:none}
.modal-input:focus{border-color:rgba(232,168,124,0.4)}
.modal-select{width:100%;background:rgba(245,240,232,0.06);border:1px solid var(--border);border-radius:10px;
  padding:11px 14px;color:var(--text);font-family:'Lora',serif;font-size:14px;outline:none;appearance:none}
.modal-textarea{width:100%;background:rgba(245,240,232,0.06);border:1px solid var(--border);border-radius:10px;
  padding:11px 14px;color:var(--text);font-family:'Lora',serif;font-size:14px;outline:none;min-height:80px;resize:none}
.modal-actions{display:flex;gap:10px;margin-top:18px}
.modal-btn{flex:1;padding:13px;border-radius:12px;font-family:'Lora',serif;font-size:13px;
  letter-spacing:1px;text-transform:uppercase;cursor:pointer;border:none}
.modal-btn.cancel{background:rgba(245,240,232,0.08);color:var(--muted)}
.modal-btn.save{background:var(--orange);color:#1A1612;font-weight:700}

/* SETTINGS PAGE */
.settings-page{padding:24px 18px}
.settings-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;margin-bottom:4px}
.settings-sub{font-size:12px;color:var(--muted);font-style:italic;margin-bottom:24px}
.settings-section{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:12px}
.settings-section h4{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
.settings-field{margin-bottom:12px}
.settings-label{font-size:12px;color:var(--muted);margin-bottom:6px;display:block}
.settings-input{width:100%;background:rgba(245,240,232,0.06);border:1px solid var(--border);border-radius:10px;
  padding:11px 14px;color:var(--text);font-family:'Lora',serif;font-size:13px;outline:none}
.settings-input:focus{border-color:rgba(232,168,124,0.4)}
.settings-btn{width:100%;background:var(--orange);color:#1A1612;border:none;border-radius:12px;
  padding:13px;font-family:'Lora',serif;font-size:13px;font-weight:700;letter-spacing:1px;
  text-transform:uppercase;cursor:pointer;margin-top:4px}
.settings-btn.danger{background:var(--rose-bg);color:var(--rose);border:1px solid rgba(201,144,154,0.3)}
.settings-msg{font-size:12px;text-align:center;margin-top:8px;min-height:18px}
</style>
</head>
<body>

<!-- SETUP SCREEN -->
<div id="setupScreen">
  <div class="setup-emoji">🔐</div>
  <div class="setup-title">One-time setup</div>
  <div class="setup-sub">Your data saves privately to your own GitHub repo. Nothing goes anywhere else. This takes two minutes.</div>
  <div class="setup-step">
    <h4>Step 1 — Create a GitHub token</h4>
    <p>Go to <code>github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)</code></p>
    <p>Click <strong>Generate new token (classic)</strong>. Name it <code>my-day-health</code>. Set expiry to 1 year. Check only the <code>repo</code> scope. Generate and copy it.</p>
  </div>
  <div class="setup-step">
    <h4>Step 2 — Paste your token below</h4>
    <p>It never leaves your phone. Stored only in your browser's local storage.</p>
    <input class="setup-input" id="setupToken" type="password" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" autocomplete="off" autocorrect="off" spellcheck="false">
  </div>
  <div class="setup-step">
    <h4>Step 3 — Confirm your repo</h4>
    <p>Your private repo where daily scores will be saved.</p>
    <input class="setup-input" id="setupRepo" value="steph-gpt/My-day-health" autocomplete="off">
  </div>
  <button class="setup-btn" onclick="completeSetup()">Connect & Start</button>
